// =====================================================================
//  aggregate.props   --   CSL properties for bus_stop_aggregate.sm
// =====================================================================

// (1) Steady-state mean queue length  L = E[n].
R{"queue"}=? [ S ]

// (2) Steady-state throughput: passengers boarded per minute.
//     In steady state this equals the *effective* arrival rate
//     lambda_eff = lambda * P(not full) minus the renege rate.
R{"boarded"}=? [ S ]

// (3) Steady-state probability the station is full (arrivals blocked).
S=? [ "full" ]

// (4) Probability the station becomes full within 60 minutes from empty.
P=? [ F<=60 "full" ]

// (5) LITTLE'S LAW CHECK (do this by hand from the numbers above):
//     Little's law:  L = lambda_eff * W   =>   W = L / lambda_eff
//     Compute  W = R{"queue"}=?[S]  /  R{"boarded"}=?[S]   and compare it
//     with the mean time-in-system from the tagged model / simulation.
//     Agreement across the three (aggregate CTMC, tagged CTMC, DES) is
//     your model-validation evidence. NOTE: because buses give BULK service,
//     this system is NOT a textbook M/M/c queue, so validate sim-vs-CTMC
//     rather than against an M/M/c closed form. (Setting C=1 with fast
//     boarding recovers an M/M/1-like sub-case you can check analytically.)
